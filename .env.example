# Copy to .env. Never commit .env.
# Dahotre Group project (ap-south-1): ref qfeuxyuyxjkmqjpiknes

# --- Public site media (Storage bucket gst-reco-site-images) ---
SUPABASE_MEDIA_URL=https://qfeuxyuyxjkmqjpiknes.supabase.co
STORAGE_PUBLIC_BUCKET=gst-reco-site-images

# Optional full public URL (trailing slash); overrides MEDIA_URL + bucket if set
# PUBLIC_SITE_MEDIA_BASE=https://qfeuxyuyxjkmqjpiknes.supabase.co/storage/v1/object/public/gst-reco-site-images/

# --- CMS / PostgREST (blog + cms pages) — can be same project or a different Supabase until you migrate tables ---
# If `posts` still lives on another project, set SUPABASE_URL + SUPABASE_ANON_KEY to that project until migration.
SUPABASE_URL=https://qfeuxyuyxjkmqjpiknes.supabase.co
SUPABASE_ANON_KEY=

# Service role (recommended for uploads to qfeuxy… bucket) or anon for that project only:
SUPABASE_SERVICE_ROLE_KEY=
# If CMS uses a different Supabase than media, set publishable key for the *media* project here for `npm run upload:media`:
SUPABASE_MEDIA_ANON_KEY=


# Vercel: vercel.json sets SUPABASE_MEDIA_URL + STORAGE_PUBLIC_BUCKET for static URLs.
# Add SUPABASE_URL + SUPABASE_ANON_KEY in Vercel → Environment variables (Production + Preview) for blog/cms and gstin-search.
# Build rewrites bare media filenames in HTML to Storage URLs; it does not require media files on the builder (see .vercelignore).

# --- GSTIN public search (Edge Function gstin-public-search on this Supabase project) ---
# Set in Supabase Dashboard → Edge Functions → Secrets (not in this .env file):
#   MV_API_KEY, MV_SECRET_KEY, COMPANY_GSTIN
# Deploy: supabase functions deploy gstin-public-search --no-verify-jwt
# See supabase/functions/gstin-public-search/README.md
